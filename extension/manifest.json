{
    "manifest_version": 3,
    "name": "Media Fetch Downloader",
    "description": "Download videos from YouTube, Instagram, TikTok, Twitter/X in any quality — powered by Media Fetch.",
    "version": "1.0.5",
    "icons": {
        "16": "icons/icon16_v2.png",
        "32": "icons/icon32_v2.png",
        "48": "icons/icon48_v2.png",
        "128": "icons/icon128_v2.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16_v2.png",
            "32": "icons/icon32_v2.png",
            "48": "icons/icon48_v2.png"
        }
    },
    "permissions": [
        "activeTab",
        "downloads",
        "notifications",
        "storage",
        "tabs",
        "scripting",
        "cookies"
    ],
    "host_permissions": [
        "http://*/*",
        "http://localhost:8000/*",
        "https://*.youtube.com/*",
        "https://*.instagram.com/*",
        "https://*.tiktok.com/*",
        "https://*.twitter.com/*",
        "https://*.x.com/*",
        "https://*.facebook.com/*",
        "https://fb.watch/*",
        "https://*.reddit.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/*",
                "https://m.youtube.com/*",
                "https://www.instagram.com/*",
                "https://www.tiktok.com/*",
                "https://www.facebook.com/*",
                "https://fb.watch/*",
                "https://www.reddit.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["popup.html", "popup.js", "popup.css", "icons/*"],
            "matches": ["<all_urls>"]
        }
    ]
}